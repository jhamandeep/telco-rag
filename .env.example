# Endpoints
OLLAMA_URL=http://localhost:11434
COLLECTION=telco_ran

# Vector store: "server" (Docker, persistent) is required for the 26k corpus.
# "local" writes an embedded file the dashboard can't see (a known gotcha).
QDRANT_MODE=server
QDRANT_PATH=./qdrant_storage
QDRANT_URL=http://localhost:6333

# Embedder (Ollama, GPU)
EMBED_MODEL=nomic-embed-text

# Generator: "local" (5070 via Ollama) or "openai"
GENERATOR=local
LOCAL_GEN_MODEL=qwen2.5:7b
OPENAI_MODEL=gpt-5.5
OPENAI_API_KEY=

# Optional: override the generator for the rewrite step only (local|openai)
# REWRITE_BACKEND=openai

# Reranker (used in the rerank phase)
RERANK_MODEL=BAAI/bge-reranker-base

# Retrieval / chunking
TOP_K=10
RERANK_TOP_N=5
CHUNK_MODE=structure
